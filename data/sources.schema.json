{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Ecosystem Radar Sources",
  "type": "object",
  "required": ["sources"],
  "properties": {
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name":    { "type": "string", "minLength": 1, "maxLength": 60 },
          "type":    { "type": "string", "enum": ["rss", "twitter"] },
          "url":     { "type": "string", "format": "uri" },
          "account": { "type": "string", "pattern": "^[A-Za-z0-9_]{1,50}$" }
        },
        "if":   { "properties": { "type": { "const": "rss" } } },
        "then": { "required": ["url"] },
        "else": { "required": ["account"] }
      }
    }
  }
}
